<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Minha Aventura</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(to bottom, #1e3c72, #2a5298);
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      text-align: center;
    }

    .capa {
      background: rgba(0, 0, 0, 0.5);
      padding: 40px;
      border-radius: 15px;
    }

    h1 {
      font-size: 3em;
      margin-bottom: 20px;
    }

    p {
      font-size: 1.2em;
      margin-bottom: 30px;
    }

    .botao {
      background-color: #ffcc00;
      color: black;
      padding: 15px 30px;
      font-size: 18px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
    }

    .botao:hover {
      background-color: #ffaa00;
    }
  </style>
</head>
<body>

  <div class="capa">
    <h1>🌟 A Jornada Perdida</h1>
    <p>Prepare-se para uma aventura cheia de desafios e mistérios!</p>
    
    <a href="historia.html">
      <button class="botao">Iniciar</button>
    </a>
  </div>

</body>
</html>
